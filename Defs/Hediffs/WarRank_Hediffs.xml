<?xml version="1.0" encoding="utf-8"?>
<!--
  war rank hediffs, one def per rank (24 total).
  these mirror the table in Source/WarRanks/WarRankData.cs - the c# side owns the
  kill thresholds and decides who gets what, these defs own the actual buffs the game
  applies. if you rebalance one, change the other to match.
  the displayed name is set in code (Hediff_WarRank) so the title-set setting can swap
  it live, which is why the stage deliberately carries no <label> of its own.
-->
<Defs>
  <HediffDef>
    <defName>WarRank_Rank01</defName>
    <label>scout</label>
    <description>Military prestige rank 1. Awarded automatically from recorded humanlike and mechanoid kills. Requires 5 relevant kills. The displayed title can be changed in War Ranks mod settings.</description>
    <hediffClass>WarRanks.Hediff_WarRank</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <everCurableByItem>false</everCurableByItem>
    <tendable>false</tendable>
    <initialSeverity>1</initialSeverity>
    <minSeverity>1</minSeverity>
    <maxSeverity>1</maxSeverity>
    <stages>
      <li>
        <statFactors>
          <SocialImpact>1.02</SocialImpact>
        </statFactors>
      </li>
