<?xml version="1.0" encoding="utf-8"?>
<!--
  war rank hediffs, one def per rank (24 total).
  the kill thresholds live in Source/WarRanks/WarRankData.cs; these defs own the buffs
  the game actually applies. a soldier's kit, phased in: low ranks toughen up, mid ranks
  sharpen their aim and pick up armour, top ranks become elite. if you rebalance, this is
  the file to touch (or regenerate it).
  the displayed name comes from code (Hediff_WarRank) so the title-set setting can swap it
  live, which is why the stage carries no <label> of its own.
-->
<Defs>
  <HediffDef>
    <defName>WarRank_Rank01</defName>
    <label>scout</label>
    <description>Military prestige rank 1. Awarded automatically from recorded humanlike and mechanoid kills. Requires 2 relevant kills. The displayed title can be changed in WarRanks mod settings.</description>
    <hediffClass>WarRanks.Hediff_WarRank</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <everCurableByItem>false</everCurableByItem>
    <tendable>false</tendable>
    <initialSeverity>1</initialSeverity>
    <minSeverity>1</minSeverity>
    <maxSeverity>1</maxSeverity>
    <stages>
      <li>
        <statOffsets>
          <ShootingAccuracyPawn>0.01</ShootingAccuracyPawn>
          <MeleeHitChance>0.01</MeleeHitChance>
        </statOffsets>
        <statFactors>
          <PainShockThreshold>1.03</PainShockThreshold>
          <MentalBreakThreshold>0.99</MentalBreakThreshold>
        </statFactors>
      </li>
    </stages>
  </HediffDef>
